package numericalData;

public class CylinderComputation {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
double radius,height,surfaceArea,baseArea,volume;
final double PI=3.14159265;
radius = 2.5;
height = 6.8;
surfaceArea = (2*PI*radius*radius)+(2*PI*radius*height);
baseArea = 2*PI*radius*radius;
volume = PI*radius*radius*height;
System.out.println("The surface area of a cylinder = "+surfaceArea);
System.out.println("The base area of a cylinder = "+baseArea);
System.out.println("The volume of a cylinder = "+volume);
	}

}
